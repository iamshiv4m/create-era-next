{
  "name": "create-era-next-monorepo",
  "private": true,
  "version": "0.0.2",
  "description": "Monorepo for create-era-next: the modern ERB replacement. Contains the CLI scaffolder and the project template.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm -w create-era-next run build",
    "dev:cli": "npm -w create-era-next run dev",
    "smoke": "npm -w create-era-next run smoke",
    "lint": "eslint packages/cli/src --max-warnings=0",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,json,md}\" \"template/**/*.{json,md}\"",
    "format:template:code": "npm --prefix template run format",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,js,json,md}\" \"template/**/*.{json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "typescript": "^5.9.2"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write"
    ],
    "template/**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamshiv4m/create-era-next.git"
  },
  "license": "MIT"
}
