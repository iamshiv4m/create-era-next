{
  "name": "{{projectName}}",
  "version": "0.1.0",
  "private": true,
  "description": "{{projectName}} — built with create-era-next (Electron + React + Vite + TypeScript).",
  "homepage": "https://github.com/{{githubOwner}}/{{githubRepo}}",
  "author": {
    "name": "{{authorName}}",
    "email": "{{authorEmail}}"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/{{githubOwner}}/{{githubRepo}}.git"
  },
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "oxlint --react-plugin --vitest-plugin -c .oxlintrc.json src tests",
    "lint:fix": "oxlint --react-plugin --vitest-plugin --fix -c .oxlintrc.json src tests",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "package": "npm run build && electron-builder --dir",
    "package:mac": "npm run build && electron-builder --mac --publish never",
    "package:win": "npm run build && electron-builder --win --publish never",
    "package:linux": "npm run build && electron-builder --linux --publish never",
    "release": "npm run build && electron-builder --publish always",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-query-devtools": "^5.62.7",
    "@tanstack/react-router": "^1.169.0",
    "axios": "^1.7.9",
    "better-sqlite3": "^11.7.0",
    "electron-log": "^5.2.4",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "i18next": "^24.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.2.0",
    "react-router-dom": "^7.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.3.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,css}": [
      "oxfmt"
    ],
    "*.{ts,tsx}": [
      "oxlint --react-plugin --vitest-plugin -c .oxlintrc.json --fix"
    ]
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
